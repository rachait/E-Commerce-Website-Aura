{
  "name": "aura-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c yellow,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": ".\\.venv\\Scripts\\python.exe -m uvicorn main:app --app-dir backend --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "sync:auto": "powershell -ExecutionPolicy Bypass -File ./scripts/auto-sync.ps1 -CommitIntervalMinutes 10",
    "sync:auto:fast": "powershell -ExecutionPolicy Bypass -File ./scripts/auto-sync.ps1 -CommitIntervalMinutes 1",
    "sync:auto:once": "powershell -ExecutionPolicy Bypass -File ./scripts/auto-sync.ps1 -RunOnce"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
